# Telegram API (https://my.telegram.org)
API_ID=123456789

API_HASH=abcdef1234567890abcdef1234567890

# Control bot token (from @BotFather)
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Comma-separated Telegram user IDs who can control the bot
ADMIN_IDS=123456789,987654321

# Optional extra password for control panel commands (/auth <password>)
ADMIN_PASSWORD=

# DB URL: default is sqlite if empty, or use PostgreSQL URL
# Examples:
# DATABASE_URL=sqlite+aiosqlite:///data/telegram_manager.db
# DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/telegram_manager
DATABASE_URL=

LOG_LEVEL=INFO

# Delay controls
DEFAULT_DELAY=1.5
RANDOM_DELAY_RANGE=1.0,3.0

# Batch controls
BATCH_ENABLED=true
BATCH_SIZE=25
BATCH_DELAY=20

# Auto-reply controls
AUTO_REPLY_DELAY=3
AUTO_REPLY_KEYWORDS=اهلاً,هلا,مرحبا,السلام عليكم,هاي

# Rest mode: pauses automation actions
REST_MODE=false

# Session controls
PREFERRED_SESSION=default

# Backup
BACKUP_HOUR_UTC=2

# Safety cap for adding members to groups
SAFE_MAX_ADDS_PER_DAY=25
